import { TabWidget, ListView, HorizontalBox, VerticalBox } from "std-widgets.slint";

export struct IpPortRow {
    remote-ip: string,
    remote-port: int,
    count: int,
    down-speed: string,
    up-speed: string,
}

export struct IpProcessRow {
    remote-ip: string,
    process-name: string,
    count: int,
    down-speed: string,
    up-speed: string,
}

export struct IpPortProcessRow {
    remote-ip: string,
    remote-port: int,
    process-name: string,
    count: int,
    down-speed: string,
    up-speed: string,
}

component StatCard inherits Rectangle {
    in property <string> label;
    in property <string> value;
    background: #1e293b;
    border-radius: 8px;

    VerticalBox {
        padding: 12px;
        spacing: 4px;
        Text {
            text: root.label;
            color: #94a3b8;
            font-size: 12px;
        }
        Text {
            text: root.value;
            color: #38bdf8;
            font-size: 20px;
            font-weight: 700;
        }
    }
}

component FlexCell inherits Rectangle {
    in property <string> text;
    in property <bool> header: false;
    in property <bool> align-left: false;
    in property <brush> text-color: #e2e8f0;
    in property <int> stretch: 1;
    callback clicked();
    horizontal-stretch: root.stretch;

    TouchArea {
        enabled: root.header;
        clicked => { root.clicked(); }
    }

    Text {
        width: parent.width;
        text: root.text;
        color: root.header ? #cbd5e1 : root.text-color;
        font-size: 12px;
        font-weight: root.header ? 600 : 400;
        horizontal-alignment: root.align-left ? TextHorizontalAlignment.left : TextHorizontalAlignment.center;
        vertical-alignment: center;
        overflow: elide;
        x: root.align-left ? 8px : 0;
    }
}

component FiveColRow inherits HorizontalBox {
    width: 100%;
    padding-left: 8px;
    padding-right: 8px;
    in property <string> t1;
    in property <string> t2;
    in property <string> t3;
    in property <string> t4;
    in property <string> t5;
    in property <bool> header: false;
    in property <int> w2: 1;
    callback column-clicked(int);

    FlexCell { text: root.t1; header: root.header; align-left: true; stretch: 4; clicked => { root.column-clicked(0); } }
    FlexCell { text: root.t2; header: root.header; stretch: root.w2; clicked => { root.column-clicked(1); } }
    FlexCell { text: root.t3; header: root.header; stretch: 1; clicked => { root.column-clicked(2); } }
    FlexCell { text: root.t4; header: root.header; text-color: #38bdf8; stretch: 2; clicked => { root.column-clicked(3); } }
    FlexCell { text: root.t5; header: root.header; text-color: #34d399; stretch: 2; clicked => { root.column-clicked(4); } }
}

component SixColRow inherits HorizontalBox {
    width: 100%;
    padding-left: 8px;
    padding-right: 8px;
    in property <string> t1;
    in property <string> t2;
    in property <string> t3;
    in property <string> t4;
    in property <string> t5;
    in property <string> t6;
    in property <bool> header: false;
    callback column-clicked(int);

    FlexCell { text: root.t1; header: root.header; align-left: true; stretch: 4; clicked => { root.column-clicked(0); } }
    FlexCell { text: root.t2; header: root.header; stretch: 1; clicked => { root.column-clicked(1); } }
    FlexCell { text: root.t3; header: root.header; stretch: 3; clicked => { root.column-clicked(2); } }
    FlexCell { text: root.t4; header: root.header; stretch: 1; clicked => { root.column-clicked(3); } }
    FlexCell { text: root.t5; header: root.header; text-color: #38bdf8; stretch: 2; clicked => { root.column-clicked(4); } }
    FlexCell { text: root.t6; header: root.header; text-color: #34d399; stretch: 2; clicked => { root.column-clicked(5); } }
}

component FiveColHeader inherits Rectangle {
    in property <string> c1;
    in property <string> c2;
    in property <string> c3;
    in property <string> c4;
    in property <string> c5;
    in property <int> w2: 1;
    callback column-clicked(int);
    width: 100%;
    height: 40px;
    background: #1e293b;

    FiveColRow {
        header: true;
        w2: root.w2;
        t1: root.c1;
        t2: root.c2;
        t3: root.c3;
        t4: root.c4;
        t5: root.c5;
        column-clicked(column) => { root.column-clicked(column); }
    }
}

component SixColHeader inherits Rectangle {
    in property <string> c1;
    in property <string> c2;
    in property <string> c3;
    in property <string> c4;
    in property <string> c5;
    in property <string> c6;
    callback column-clicked(int);
    width: 100%;
    height: 40px;
    background: #1e293b;

    SixColRow {
        header: true;
        t1: root.c1;
        t2: root.c2;
        t3: root.c3;
        t4: root.c4;
        t5: root.c5;
        t6: root.c6;
        column-clicked(column) => { root.column-clicked(column); }
    }
}

component LineChartPanel inherits Rectangle {
    in property <string> download-path;
    in property <string> upload-path;
    in property <string> down-label;
    in property <string> up-label;
    height: 200px;
    background: #0f172a;
    border-radius: 8px;

    VerticalBox {
        padding: 12px;
        spacing: 8px;

        HorizontalBox {
            spacing: 16px;
            HorizontalBox {
                spacing: 6px;
                Rectangle {
                    width: 12px;
                    height: 3px;
                    background: #38bdf8;
                    y: 8px;
                }
                Text {
                    text: root.down-label;
                    color: #94a3b8;
                    font-size: 11px;
                }
            }
            HorizontalBox {
                spacing: 6px;
                Rectangle {
                    width: 12px;
                    height: 3px;
                    background: #34d399;
                    y: 8px;
                }
                Text {
                    text: root.up-label;
                    color: #94a3b8;
                    font-size: 11px;
                }
            }
        }

        chart-area := Rectangle {
            vertical-stretch: 1;
            background: #111827;
            border-radius: 6px;

            Path {
                width: parent.width;
                height: parent.height;
                commands: root.download-path;
                stroke: #38bdf8;
                stroke-width: 2px;
            }
            Path {
                width: parent.width;
                height: parent.height;
                commands: root.upload-path;
                stroke: #34d399;
                stroke-width: 2px;
            }
        }
    }
}

component IpPortTab inherits Rectangle {
    in property <[IpPortRow]> rows;
    callback sort-requested(int);
    background: #0f172a;
    border-radius: 8px;

    VerticalBox {
        width: 100%;
        padding: 0;
        FiveColHeader {
            width: 100%;
            c1: "目标 IP";
            c2: "端口";
            c3: "连接数";
            c4: "下载";
            c5: "上传";
            column-clicked(column) => { root.sort-requested(column); }
        }
        ListView {
            width: 100%;
            vertical-stretch: 1;
            for row[i] in root.rows: Rectangle {
                width: 100%;
                height: 36px;
                background: mod(i, 2) == 0 ? #0f172a : #111827;

                FiveColRow {
                    t1: row.remote-ip;
                    t2: row.remote-port;
                    t3: row.count;
                    t4: row.down-speed;
                    t5: row.up-speed;
                }
            }
        }
    }
}

component IpPortProcessTab inherits Rectangle {
    in property <[IpPortProcessRow]> rows;
    callback sort-requested(int);
    background: #0f172a;
    border-radius: 8px;

    VerticalBox {
        width: 100%;
        padding: 0;
        SixColHeader {
            width: 100%;
            c1: "目标 IP";
            c2: "端口";
            c3: "进程";
            c4: "连接数";
            c5: "下载";
            c6: "上传";
            column-clicked(column) => { root.sort-requested(column); }
        }
        ListView {
            width: 100%;
            vertical-stretch: 1;
            for row[i] in root.rows: Rectangle {
                width: 100%;
                height: 36px;
                background: mod(i, 2) == 0 ? #0f172a : #111827;

                SixColRow {
                    t1: row.remote-ip;
                    t2: row.remote-port;
                    t3: row.process-name;
                    t4: row.count;
                    t5: row.down-speed;
                    t6: row.up-speed;
                }
            }
        }
    }
}

component IpProcessTab inherits Rectangle {
    in property <[IpProcessRow]> rows;
    callback sort-requested(int);
    background: #0f172a;
    border-radius: 8px;

    VerticalBox {
        width: 100%;
        padding: 0;
        FiveColHeader {
            width: 100%;
            c1: "目标 IP";
            c2: "进程";
            c3: "连接数";
            c4: "下载";
            c5: "上传";
            w2: 3;
            column-clicked(column) => { root.sort-requested(column); }
        }
        ListView {
            width: 100%;
            vertical-stretch: 1;
            for row[i] in root.rows: Rectangle {
                width: 100%;
                height: 36px;
                background: mod(i, 2) == 0 ? #0f172a : #111827;

                FiveColRow {
                    w2: 3;
                    t1: row.remote-ip;
                    t2: row.process-name;
                    t3: row.count;
                    t4: row.down-speed;
                    t5: row.up-speed;
                }
            }
        }
    }
}

export component MainWindow inherits Window {
    title: "Windows 网络连接与流量监控";
    preferred-width: 960px;
    preferred-height: 780px;
    min-width: 720px;
    min-height: 560px;
    background: #020617;

    in property <int> total-count: 0;
    in property <string> total-down-speed: "0 B/s";
    in property <string> total-up-speed: "0 B/s";
    in property <[IpPortRow]> ip-port-rows: [];
    in property <[IpProcessRow]> ip-process-rows: [];
    in property <[IpPortProcessRow]> ip-port-process-rows: [];
    in property <string> download-path: "";
    in property <string> upload-path: "";
    in property <string> status-text: "正在加载…";
    in property <string> last-updated: "";

    callback refresh-requested();
    callback sort-requested(int, int);

    VerticalBox {
        width: 100%;
        padding: 20px;
        spacing: 14px;

        HorizontalBox {
            spacing: 12px;
            alignment: space-between;

            Text {
                text: "Windows 网络连接与流量监控";
                color: #f8fafc;
                font-size: 22px;
                font-weight: 700;
                vertical-alignment: center;
            }

            Rectangle {
                width: 88px;
                height: 36px;
                background: refresh-touch.has-hover ? #0284c7 : #0ea5e9;
                border-radius: 6px;
                refresh-touch := TouchArea {
                    clicked => { root.refresh-requested(); }
                }
                Text {
                    text: "刷新";
                    color: #ffffff;
                    font-size: 14px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        HorizontalBox {
            spacing: 12px;
            StatCard {
                horizontal-stretch: 1;
                label: "TCP 连接数";
                value: root.total-count;
            }
            StatCard {
                horizontal-stretch: 1;
                label: "总下载速度";
                value: root.total-down-speed;
            }
            StatCard {
                horizontal-stretch: 1;
                label: "总上传速度";
                value: root.total-up-speed;
            }
        }

        LineChartPanel {
            width: 100%;
            download-path: root.download-path;
            upload-path: root.upload-path;
            down-label: "下载 " + root.total-down-speed;
            up-label: "上传 " + root.total-up-speed;
        }

        Rectangle {
            background: #1e293b;
            border-radius: 8px;
            height: 52px;
            VerticalBox {
                padding: 10px;
                spacing: 2px;
                Text {
                    text: root.status-text;
                    color: #94a3b8;
                    font-size: 12px;
                }
                Text {
                    text: "上次更新: " + root.last-updated;
                    color: #64748b;
                    font-size: 11px;
                }
            }
        }

        TabWidget {
            width: 100%;
            vertical-stretch: 1;

            Tab {
                title: "按目标 IP + 端口";
                IpPortTab {
                    width: 100%;
                    rows: root.ip-port-rows;
                    sort-requested(column) => { root.sort-requested(0, column); }
                }
            }

            Tab {
                title: "按目标 IP + 进程";
                IpProcessTab {
                    width: 100%;
                    rows: root.ip-process-rows;
                    sort-requested(column) => { root.sort-requested(1, column); }
                }
            }

            Tab {
                title: "按 IP + 端口 + 进程";
                IpPortProcessTab {
                    width: 100%;
                    rows: root.ip-port-process-rows;
                    sort-requested(column) => { root.sort-requested(2, column); }
                }
            }
        }
    }
}
