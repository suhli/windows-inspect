import { TabWidget, ListView, HorizontalBox, VerticalBox } from "std-widgets.slint";

export struct IpPortRow {
    remote-ip: string,
    remote-port: int,
    count: int,
}

export struct IpProcessRow {
    remote-ip: string,
    process-name: string,
    count: int,
}

component StatCard inherits Rectangle {
    in property <string> label;
    in property <string> value;
    background: #1e293b;
    border-radius: 8px;

    VerticalBox {
        padding: 16px;
        spacing: 4px;
        Text {
            text: root.label;
            color: #94a3b8;
            font-size: 13px;
        }
        Text {
            text: root.value;
            color: #38bdf8;
            font-size: 28px;
            font-weight: 700;
        }
    }
}

component TableHeader3 inherits Rectangle {
    in property <string> col1;
    in property <string> col2;
    in property <string> col3;
    height: 40px;
    background: #1e293b;

    HorizontalBox {
        Rectangle {
            horizontal-stretch: 2;
            Text {
                text: root.col1;
                color: #cbd5e1;
                font-size: 13px;
                font-weight: 600;
                vertical-alignment: center;
                x: 12px;
            }
        }
        Rectangle {
            horizontal-stretch: 1;
            Text {
                text: root.col2;
                color: #cbd5e1;
                font-size: 13px;
                font-weight: 600;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
        Rectangle {
            horizontal-stretch: 1;
            Text {
                text: root.col3;
                color: #cbd5e1;
                font-size: 13px;
                font-weight: 600;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}

component IpPortTab inherits Rectangle {
    in property <[IpPortRow]> rows;
    background: #0f172a;
    border-radius: 8px;

    VerticalBox {
        padding: 0;
        TableHeader3 {
            col1: "目标 IP";
            col2: "端口";
            col3: "连接数";
        }
        ListView {
            vertical-stretch: 1;
            for row[i] in root.rows: Rectangle {
                height: 36px;
                background: mod(i, 2) == 0 ? #0f172a : #111827;

                HorizontalBox {
                    Rectangle {
                        horizontal-stretch: 2;
                        Text {
                            text: row.remote-ip;
                            color: #e2e8f0;
                            font-size: 13px;
                            vertical-alignment: center;
                            x: 12px;
                        }
                    }
                    Rectangle {
                        horizontal-stretch: 1;
                        Text {
                            text: row.remote-port;
                            color: #e2e8f0;
                            font-size: 13px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                    Rectangle {
                        horizontal-stretch: 1;
                        Text {
                            text: row.count;
                            color: #38bdf8;
                            font-size: 13px;
                            font-weight: 600;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}

component IpProcessTab inherits Rectangle {
    in property <[IpProcessRow]> rows;
    background: #0f172a;
    border-radius: 8px;

    VerticalBox {
        padding: 0;
        TableHeader3 {
            col1: "目标 IP";
            col2: "进程";
            col3: "连接数";
        }
        ListView {
            vertical-stretch: 1;
            for row[i] in root.rows: Rectangle {
                height: 36px;
                background: mod(i, 2) == 0 ? #0f172a : #111827;

                HorizontalBox {
                    Rectangle {
                        horizontal-stretch: 2;
                        Text {
                            text: row.remote-ip;
                            color: #e2e8f0;
                            font-size: 13px;
                            vertical-alignment: center;
                            x: 12px;
                        }
                    }
                    Rectangle {
                        horizontal-stretch: 1;
                        Text {
                            text: row.process-name;
                            color: #e2e8f0;
                            font-size: 13px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                    Rectangle {
                        horizontal-stretch: 1;
                        Text {
                            text: row.count;
                            color: #38bdf8;
                            font-size: 13px;
                            font-weight: 600;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}

export component MainWindow inherits Window {
    title: "Windows TCP 网络监控";
    preferred-width: 900px;
    preferred-height: 640px;
    background: #020617;

    in property <int> total-count: 0;
    in property <[IpPortRow]> ip-port-rows: [];
    in property <[IpProcessRow]> ip-process-rows: [];
    in property <string> status-text: "正在加载…";
    in property <string> last-updated: "";

    callback refresh-requested();

    VerticalBox {
        padding: 20px;
        spacing: 16px;

        HorizontalBox {
            spacing: 12px;
            alignment: space-between;

            Text {
                text: "Windows TCP 网络监控";
                color: #f8fafc;
                font-size: 22px;
                font-weight: 700;
                vertical-alignment: center;
            }

            Rectangle {
                width: 88px;
                height: 36px;
                background: refresh-touch.has-hover ? #0284c7 : #0ea5e9;
                border-radius: 6px;
                refresh-touch := TouchArea {
                    clicked => { root.refresh-requested(); }
                }
                Text {
                    text: "刷新";
                    color: #ffffff;
                    font-size: 14px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        HorizontalBox {
            spacing: 16px;
            StatCard {
                horizontal-stretch: 1;
                label: "TCP 连接总数";
                value: root.total-count;
            }
            Rectangle {
                horizontal-stretch: 2;
                background: #1e293b;
                border-radius: 8px;
                VerticalBox {
                    padding: 12px;
                    spacing: 4px;
                    Text {
                        text: root.status-text;
                        color: #94a3b8;
                        font-size: 12px;
                    }
                    Text {
                        text: "上次更新: " + root.last-updated;
                        color: #64748b;
                        font-size: 11px;
                    }
                }
            }
        }

        TabWidget {
            vertical-stretch: 1;

            Tab {
                title: "按目标 IP + 端口";
                IpPortTab {
                    rows: root.ip-port-rows;
                }
            }

            Tab {
                title: "按目标 IP + 进程";
                IpProcessTab {
                    rows: root.ip-process-rows;
                }
            }
        }
    }
}
