import { TabWidget, ListView, HorizontalBox, VerticalBox } from "std-widgets.slint";

export struct IpPortRow {
    remote-ip: string,
    remote-port: int,
    count: int,
    down-speed: string,
    up-speed: string,
}

export struct IpProcessRow {
    remote-ip: string,
    process-name: string,
    count: int,
    down-speed: string,
    up-speed: string,
}

export struct IpPortProcessRow {
    remote-ip: string,
    remote-port: int,
    process-name: string,
    count: int,
    down-speed: string,
    up-speed: string,
}

component StatCard inherits Rectangle {
    in property <string> label;
    in property <string> value;
    background: #1e293b;
    border-radius: 8px;

    VerticalBox {
        padding: 12px;
        spacing: 4px;
        Text {
            text: root.label;
            color: #94a3b8;
            font-size: 12px;
        }
        Text {
            text: root.value;
            color: #38bdf8;
            font-size: 20px;
            font-weight: 700;
        }
    }
}

component ColIp inherits Rectangle {
    in property <string> cell-text;
    in property <bool> is-header: false;
    width: 210px;
    Text {
        text: root.cell-text;
        color: root.is-header ? #cbd5e1 : #e2e8f0;
        font-size: 12px;
        font-weight: root.is-header ? 600 : 400;
        vertical-alignment: center;
        x: 8px;
        overflow: elide;
    }
}

component ColCenter inherits Rectangle {
    in property <string> cell-text;
    in property <length> cell-width;
    in property <bool> is-header: false;
    in property <brush> cell-color: #e2e8f0;
    width: root.cell-width;
    Text {
        text: root.cell-text;
        color: root.is-header ? #cbd5e1 : root.cell-color;
        font-size: 12px;
        font-weight: root.is-header ? 600 : 400;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }
}

component FiveColHeader inherits Rectangle {
    in property <string> c1;
    in property <string> c2;
    in property <string> c3;
    in property <string> c4;
    in property <string> c5;
    in property <length> col2-width: 58px;
    height: 40px;
    background: #1e293b;

    HorizontalBox {
        padding-left: 8px;
        ColIp { cell-text: root.c1; is-header: true; }
        ColCenter { cell-text: root.c2; cell-width: root.col2-width; is-header: true; }
        ColCenter { cell-text: root.c3; cell-width: 52px; is-header: true; }
        ColCenter { cell-text: root.c4; cell-width: 96px; is-header: true; cell-color: #38bdf8; }
        ColCenter { cell-text: root.c5; cell-width: 96px; is-header: true; cell-color: #34d399; }
    }
}

component SixColHeader inherits Rectangle {
    in property <string> c1;
    in property <string> c2;
    in property <string> c3;
    in property <string> c4;
    in property <string> c5;
    in property <string> c6;
    height: 40px;
    background: #1e293b;

    HorizontalBox {
        padding-left: 8px;
        ColIp { cell-text: root.c1; is-header: true; }
        ColCenter { cell-text: root.c2; cell-width: 52px; is-header: true; }
        ColCenter { cell-text: root.c3; cell-width: 120px; is-header: true; }
        ColCenter { cell-text: root.c4; cell-width: 52px; is-header: true; }
        ColCenter { cell-text: root.c5; cell-width: 92px; is-header: true; cell-color: #38bdf8; }
        ColCenter { cell-text: root.c6; cell-width: 92px; is-header: true; cell-color: #34d399; }
    }
}

component LineChartPanel inherits Rectangle {
    in property <string> download-path;
    in property <string> upload-path;
    in property <string> down-label;
    in property <string> up-label;
    height: 200px;
    background: #0f172a;
    border-radius: 8px;

    VerticalBox {
        padding: 12px;
        spacing: 8px;

        HorizontalBox {
            spacing: 16px;
            HorizontalBox {
                spacing: 6px;
                Rectangle {
                    width: 12px;
                    height: 3px;
                    background: #38bdf8;
                    y: 8px;
                }
                Text {
                    text: root.down-label;
                    color: #94a3b8;
                    font-size: 11px;
                }
            }
            HorizontalBox {
                spacing: 6px;
                Rectangle {
                    width: 12px;
                    height: 3px;
                    background: #34d399;
                    y: 8px;
                }
                Text {
                    text: root.up-label;
                    color: #94a3b8;
                    font-size: 11px;
                }
            }
        }

        chart-area := Rectangle {
            vertical-stretch: 1;
            background: #111827;
            border-radius: 6px;

            Path {
                width: parent.width;
                height: parent.height;
                commands: root.download-path;
                stroke: #38bdf8;
                stroke-width: 2px;
            }
            Path {
                width: parent.width;
                height: parent.height;
                commands: root.upload-path;
                stroke: #34d399;
                stroke-width: 2px;
            }
        }
    }
}

component IpPortTab inherits Rectangle {
    in property <[IpPortRow]> rows;
    background: #0f172a;
    border-radius: 8px;

    VerticalBox {
        padding: 0;
        FiveColHeader {
            c1: "目标 IP";
            c2: "端口";
            c3: "连接数";
            c4: "下载";
            c5: "上传";
            col2-width: 58px;
        }
        ListView {
            vertical-stretch: 1;
            for row[i] in root.rows: Rectangle {
                height: 36px;
                background: mod(i, 2) == 0 ? #0f172a : #111827;

                HorizontalBox {
                    padding-left: 8px;
                    ColIp { cell-text: row.remote-ip; }
                    ColCenter { cell-text: row.remote-port; cell-width: 58px; }
                    ColCenter { cell-text: row.count; cell-width: 52px; }
                    ColCenter { cell-text: row.down-speed; cell-width: 96px; cell-color: #38bdf8; }
                    ColCenter { cell-text: row.up-speed; cell-width: 96px; cell-color: #34d399; }
                }
            }
        }
    }
}

component IpPortProcessTab inherits Rectangle {
    in property <[IpPortProcessRow]> rows;
    background: #0f172a;
    border-radius: 8px;

    VerticalBox {
        padding: 0;
        SixColHeader {
            c1: "目标 IP";
            c2: "端口";
            c3: "进程";
            c4: "连接数";
            c5: "下载";
            c6: "上传";
        }
        ListView {
            vertical-stretch: 1;
            for row[i] in root.rows: Rectangle {
                height: 36px;
                background: mod(i, 2) == 0 ? #0f172a : #111827;

                HorizontalBox {
                    padding-left: 8px;
                    ColIp { cell-text: row.remote-ip; }
                    ColCenter { cell-text: row.remote-port; cell-width: 52px; }
                    ColCenter { cell-text: row.process-name; cell-width: 120px; }
                    ColCenter { cell-text: row.count; cell-width: 52px; }
                    ColCenter { cell-text: row.down-speed; cell-width: 92px; cell-color: #38bdf8; }
                    ColCenter { cell-text: row.up-speed; cell-width: 92px; cell-color: #34d399; }
                }
            }
        }
    }
}

component IpProcessTab inherits Rectangle {
    in property <[IpProcessRow]> rows;
    background: #0f172a;
    border-radius: 8px;

    VerticalBox {
        padding: 0;
        FiveColHeader {
            c1: "目标 IP";
            c2: "进程";
            c3: "连接数";
            c4: "下载";
            c5: "上传";
            col2-width: 150px;
        }
        ListView {
            vertical-stretch: 1;
            for row[i] in root.rows: Rectangle {
                height: 36px;
                background: mod(i, 2) == 0 ? #0f172a : #111827;

                HorizontalBox {
                    padding-left: 8px;
                    ColIp { cell-text: row.remote-ip; }
                    ColCenter { cell-text: row.process-name; cell-width: 150px; }
                    ColCenter { cell-text: row.count; cell-width: 52px; }
                    ColCenter { cell-text: row.down-speed; cell-width: 96px; cell-color: #38bdf8; }
                    ColCenter { cell-text: row.up-speed; cell-width: 96px; cell-color: #34d399; }
                }
            }
        }
    }
}

export component MainWindow inherits Window {
    title: "Windows TCP 网络监控";
    preferred-width: 960px;
    preferred-height: 780px;
    background: #020617;

    in property <int> total-count: 0;
    in property <string> total-down-speed: "0 B/s";
    in property <string> total-up-speed: "0 B/s";
    in property <[IpPortRow]> ip-port-rows: [];
    in property <[IpProcessRow]> ip-process-rows: [];
    in property <[IpPortProcessRow]> ip-port-process-rows: [];
    in property <string> download-path: "";
    in property <string> upload-path: "";
    in property <string> status-text: "正在加载…";
    in property <string> last-updated: "";

    callback refresh-requested();

    VerticalBox {
        padding: 20px;
        spacing: 14px;

        HorizontalBox {
            spacing: 12px;
            alignment: space-between;

            Text {
                text: "Windows TCP 网络监控";
                color: #f8fafc;
                font-size: 22px;
                font-weight: 700;
                vertical-alignment: center;
            }

            Rectangle {
                width: 88px;
                height: 36px;
                background: refresh-touch.has-hover ? #0284c7 : #0ea5e9;
                border-radius: 6px;
                refresh-touch := TouchArea {
                    clicked => { root.refresh-requested(); }
                }
                Text {
                    text: "刷新";
                    color: #ffffff;
                    font-size: 14px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        HorizontalBox {
            spacing: 12px;
            StatCard {
                horizontal-stretch: 1;
                label: "TCP 连接数";
                value: root.total-count;
            }
            StatCard {
                horizontal-stretch: 1;
                label: "总下载速度";
                value: root.total-down-speed;
            }
            StatCard {
                horizontal-stretch: 1;
                label: "总上传速度";
                value: root.total-up-speed;
            }
        }

        LineChartPanel {
            download-path: root.download-path;
            upload-path: root.upload-path;
            down-label: "下载 " + root.total-down-speed;
            up-label: "上传 " + root.total-up-speed;
        }

        Rectangle {
            background: #1e293b;
            border-radius: 8px;
            height: 52px;
            VerticalBox {
                padding: 10px;
                spacing: 2px;
                Text {
                    text: root.status-text;
                    color: #94a3b8;
                    font-size: 12px;
                }
                Text {
                    text: "上次更新: " + root.last-updated;
                    color: #64748b;
                    font-size: 11px;
                }
            }
        }

        TabWidget {
            vertical-stretch: 1;

            Tab {
                title: "按目标 IP + 端口";
                IpPortTab {
                    rows: root.ip-port-rows;
                }
            }

            Tab {
                title: "按目标 IP + 进程";
                IpProcessTab {
                    rows: root.ip-process-rows;
                }
            }

            Tab {
                title: "按 IP + 端口 + 进程";
                IpPortProcessTab {
                    rows: root.ip-port-process-rows;
                }
            }
        }
    }
}
